<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            >
    <!-- LEFT : Quick Subjects List -->
    <left>
        <VBox spacing="10" prefWidth="220" style="-fx-background-color: #f4f4f4;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="Subjects"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <TextField fx:id="searchField"
                       promptText="Search subject..."/>

            <ListView fx:id="subjectsListView"
                      VBox.vgrow="ALWAYS"/>

            <Button fx:id="newSubjectBtn"
                    text="+ New Subject"
                    maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- CENTER : Subject Form -->
    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <Label text="Subject Details"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <GridPane hgap="10" vgap="12">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nameField"
                           promptText="e.g Mathematics"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Description:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextArea fx:id="descriptionField"
                          promptText="Optional description"
                          prefRowCount="4"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button fx:id="saveBtn" text="Save" />
                <Button fx:id="deleteBtn" text="Delete" />
                <Button fx:id="cancelBtn" text="Cancel" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
