<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.andali.schoolreports.controller.SubjectsController">

    <!-- Top: Search + Add button -->
    <top>
        <HBox spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
         <Button fx:id="backBtn" mnemonicParsing="false" text="&lt;-" />
            <TextField fx:id="searchField" prefHeight="25.0" prefWidth="443.0" promptText="Search subjects..." HBox.hgrow="ALWAYS" />
            <Button fx:id="addSubjectBtn" text="Add Subject" />
        </HBox>
    </top>

    <!-- Center: Main Table -->
    <center>
        <TableView fx:id="subjectsTable" prefHeight="400">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="50" text="ID" />
                <TableColumn fx:id="nameColumn" prefWidth="200" text="Name" />
                <TableColumn fx:id="descriptionColumn" prefWidth="300" text="Description" />
                <TableColumn fx:id="classColumn" prefWidth="150" text="Class" />
            </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
        </TableView>
    </center>

    <!-- Left: Quick List + Form -->
    <left>
        <VBox fx:id="formPanel" managed="false" prefWidth="250" spacing="10" visible="false">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Label text="Quick List" />
            <ListView fx:id="quickListView" prefHeight="150" />
            <Label text="Subject Details" />
            <TextField fx:id="nameField" promptText="Name" />
            <TextField fx:id="descriptionField" promptText="Description" />
            <ChoiceBox fx:id="classChoice" prefWidth="200" />
            <HBox spacing="10">
                <Button fx:id="saveBtn" text="Save" />
                <Button fx:id="cancelBtn" text="Cancel" />
            </HBox>
        </VBox>
    </left>

</BorderPane>
