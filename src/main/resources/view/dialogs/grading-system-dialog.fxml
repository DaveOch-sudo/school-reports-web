<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.andali.schoolreports.controller.dialogs.GradingSystemDialogController"
      prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: white;">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   
   <children>
      <Label text="Create Grading System">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <Separator prefWidth="200.0" />
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label text="Grading System Name:" prefWidth="150.0">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TextField fx:id="gradingScaleNameField" prefWidth="300.0" promptText="e.g., Standard Grading" />
         </children>
      </HBox>
      
      <VBox spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <Label text="Grade Steps:">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            
            <TableView fx:id="gradeStepsTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="gradeColumn" text="Grade" prefWidth="100.0" />
                  <TableColumn fx:id="minScoreColumn" text="Min Score" prefWidth="120.0" />
                  <TableColumn fx:id="maxScoreColumn" text="Max Score" prefWidth="120.0" />
                  <TableColumn fx:id="remarkColumn" text="Remark" prefWidth="220.0" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <Button fx:id="addStepBtn" text="+ Add Step" onAction="#handleAddStep" 
                          style="-fx-background-color: #1E88E5;" textFill="WHITE">
                     <padding>
                        <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                  </Button>
                  <Button fx:id="removeStepBtn" text="- Remove Selected" onAction="#handleRemoveStep"
                          style="-fx-background-color: #D32F2F;" textFill="WHITE">
                     <padding>
                        <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
      
      <Separator prefWidth="200.0" />
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="cancelBtn" text="Cancel" onAction="#handleCancel" prefWidth="100.0"
                    style="-fx-background-color: white; -fx-border-color: #AAAAAB; -fx-border-radius: 5;">
               <padding>
                  <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
               </padding>
            </Button>
            <Button fx:id="saveBtn" text="Save" onAction="#handleSave" prefWidth="100.0"
                    style="-fx-background-color: #4CAF50;" textFill="WHITE">
               <padding>
                  <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
               </padding>
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
