<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="645.0" prefWidth="653.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.andali.schoolreports.controller.GeneralMarksheetLandingController">

    <!-- TOP: Title + Summary -->
    <top>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="General Marksheets" />

            <HBox spacing="15">
                <VBox styleClass="summary-card">
                    <Label text="Total Marksheets" />
                    <Label fx:id="totalMarksheetsLabel" text="0" />
                </VBox>

                <VBox styleClass="summary-card">
                    <Label text="Classes Covered" />
                    <Label fx:id="classesCoveredLabel" text="0" />
                </VBox>

                <VBox styleClass="summary-card">
                    <Label text="Exams Covered" />
                    <Label fx:id="examsCoveredLabel" text="0" />
                </VBox>

                <VBox styleClass="summary-card">
                    <Label text="Last Generated" />
                    <Label fx:id="lastGeneratedLabel" text="—" />
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: Table of generated marksheets -->
    <center>
        <TableView fx:id="marksheetTable" prefHeight="500">
            <columns>
                <TableColumn fx:id="classColumn" text="Class" />
                <TableColumn fx:id="termColumn" text="Term" />
                <TableColumn fx:id="examColumn" text="Exam" />
                <TableColumn fx:id="studentsCountColumn" text="Students" />
                <TableColumn fx:id="subjectsCountColumn" text="Subjects" />
                <TableColumn fx:id="averageColumn" text="Average" />
                <TableColumn fx:id="statusColumn" text="Status" />
                <TableColumn fx:id="generatedOnColumn" prefWidth="92.0" text="Generated On" />
            </columns>
        </TableView>
    </center>

    <!-- BOTTOM: Actions -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
            <Button fx:id="generateButton" style="-fx-font-weight: bold;" text="Generate New" />

            <Button text="View" />
            <Button text="Print" />
            <Button text="Export PDF" />
        </HBox>
    </bottom>

</BorderPane>
