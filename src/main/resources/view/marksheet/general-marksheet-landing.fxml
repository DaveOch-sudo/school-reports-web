<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.andali.schoolreports.controller.GeneralMarksheetSummaryController">

    <!-- HEADER -->
    <top>
        <VBox spacing="5" style="-fx-padding: 20; -fx-background-color: white;">

            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="General Marksheet Dashboard" />

            <Label style="-fx-text-fill: #777777;" text="Overview of all generated general marksheets" />
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- SUMMARY CARDS -->
            <HBox spacing="15">

                <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label style="-fx-text-fill: #666666;" text="Total Marksheets" />
                    <Label fx:id="totalMarksheetsLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="0" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label style="-fx-text-fill: #666666;" text="Classes Covered" />
                    <Label fx:id="classesCoveredLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="0" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label style="-fx-text-fill: #666666;" text="Exams Covered" />
                    <Label fx:id="examsCoveredLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="0" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label style="-fx-text-fill: #666666;" text="Last Generated" />
                    <Label fx:id="lastGeneratedLabel" style="-fx-font-size: 14px;" text="—" />
                </VBox>

            </HBox>

            <!-- TOOLBAR -->
            <HBox alignment="CENTER_LEFT" spacing="10">

                <Button fx:id="generateButton" style="-fx-font-weight: bold;                                -fx-background-color: #4CAF50;                                -fx-text-fill: white;                                -fx-background-radius: 6;" text="Generate New" />

                <Button fx:id="viewButton" text="View" />
                <Button text="Export PDF" />

            </HBox>
         <StackPane VBox.vgrow="ALWAYS">
            <children>
      
                  <!-- TABLE -->
                  <TableView fx:id="marksheetTable" style="-fx-background-color: white;">
      
                      <columns>
                          <TableColumn fx:id="classColumn" text="Class" />
                          <TableColumn fx:id="termColumn" text="Term" />
                          <TableColumn fx:id="examColumn" text="Exam" />
                          <TableColumn fx:id="studentsCountColumn" text="Students" />
                          <TableColumn fx:id="subjectsCountColumn" text="Subjects" />
                          <TableColumn fx:id="averageColumn" text="Average" />
                          <TableColumn fx:id="statusColumn" text="Status" />
                          <TableColumn fx:id="generatedOnColumn" prefWidth="120" text="Generated On" />
                      </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
      
                  </TableView>
               <ProgressIndicator fx:id="tableProgressIndicator" visible="false" />
            </children>
         </StackPane>

        </VBox>
    </center>

</BorderPane>
