<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="438.0" prefWidth="892.0" spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.andali.schoolreports.controller.GeneralMarksheetController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="63.0" prefWidth="666.0" spacing="10.0" style="-fx-border-color: #aaaa; -fx-border-width: 0 0 1 0;" VBox.vgrow="NEVER">
         <children>
            <Label text="Class:" />
            <ChoiceBox prefHeight="25.0" prefWidth="113.0" />
            <Label text="Term:" />
            <ChoiceBox prefHeight="25.0" prefWidth="89.0" />
            <Label text="Exam Type:" />
            <ChoiceBox prefHeight="25.0" prefWidth="105.0" />
            <Button mnemonicParsing="false" text="Create Reports" />
            <Region prefHeight="41.0" prefWidth="19.0" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="Export PDF" />
            <Button mnemonicParsing="false" text="Print" />
         </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
      </HBox>
      <AnchorPane VBox.vgrow="ALWAYS">
         <children>
            <TableView prefHeight="317.0" prefWidth="892.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
              <columns>
                <TableColumn prefWidth="75.0" text="C1" />
                <TableColumn prefWidth="75.0" text="C2" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets left="5.0" right="5.0" />
         </padding>
      </AnchorPane>
      <VBox alignment="CENTER" VBox.vgrow="NEVER">
         <VBox.margin>
            <Insets left="10.0" right="10.0" />
         </VBox.margin>
         <children>
            <HBox alignment="CENTER" maxHeight="50.0" prefHeight="50.0" spacing="10.0" style="-fx-background-color: white;" VBox.vgrow="NEVER">
               <children>
                  <Label text="Highest Marks: 00" />
                  <Separator orientation="VERTICAL" prefHeight="17.0" prefWidth="6.0" HBox.hgrow="ALWAYS" />
                  <Label text="Lowest Marks: 100" />
                  <Separator orientation="VERTICAL" prefHeight="17.0" prefWidth="6.0" HBox.hgrow="ALWAYS" />
                  <Label text="Class Average: 23.3" />
                  <Separator orientation="VERTICAL" prefHeight="17.0" prefWidth="6.0" HBox.hgrow="ALWAYS" />
                  <Label text="Pass Count: 23" textFill="#087917" />
                  <Separator orientation="VERTICAL" prefHeight="17.0" prefWidth="6.0" HBox.hgrow="ALWAYS" />
                  <Label text="Fail Count: 3" textFill="#a80b0b" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Separator prefWidth="200.0" VBox.vgrow="NEVER" />
      <HBox alignment="CENTER_LEFT" prefHeight="49.0" prefWidth="892.0" spacing="10.0" VBox.vgrow="NEVER">
         <children>
            <Button mnemonicParsing="false" style="-fx-background-color: green;" text="Export to Excel" textFill="WHITE" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="Close" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="4.0" />
         </padding>
      </HBox>
   </children>
</VBox>
